{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openaccp.dev/schemas/handoff.schema.json",
  "title": "OpenACCP Handoff",
  "type": "object",
  "required": ["schemaVersion", "artifactType", "handoffId", "taskId", "responseId", "actorRole", "authority", "workspaceRef", "worktree", "branchRef", "baseCommit", "commit", "dataRisk", "effectsPreset", "changedFiles", "changedArtifacts", "claims", "verificationEvidence", "deviations", "risks", "assumptionsUsed", "remainingWork", "stateClaim"],
  "properties": {
    "schemaVersion": { "const": "openaccp-handoff.v1" },
    "artifactType": { "const": "handoff" },
    "handoffId": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "responseId": { "type": "string", "minLength": 1 },
    "actorRole": { "enum": ["worker", "frontier", "reviewer", "discovery"] },
    "authority": { "enum": ["B0", "B1", "B2", "B3"] },
    "workspaceRef": { "type": "string", "minLength": 1 },
    "worktree": { "type": "string", "minLength": 1 },
    "branchRef": { "type": "string", "minLength": 1 },
    "baseCommit": { "type": "string", "minLength": 1 },
    "commit": { "type": "string", "minLength": 1 },
    "dataRisk": { "enum": ["none", "low", "medium", "high", "sensitive"] },
    "effectsPreset": { "enum": ["read_only_handoff", "review_handoff", "orchestration_local_write", "docs_task_card_commit", "implementation_local_commit", "primary_only", "custom_expanded"] },
    "changedFiles": { "$ref": "#/$defs/nonEmptyStrings" },
    "changedArtifacts": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["path", "changeType"], "additionalProperties": true } },
    "claims": { "$ref": "#/$defs/nonEmptyStrings" },
    "verificationEvidence": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["check", "method", "result"], "additionalProperties": true } },
    "deviations": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "assumptionsUsed": { "type": "array", "items": { "type": "string" } },
    "remainingWork": { "type": "array", "items": { "type": "string" } },
    "stateClaim": { "enum": ["proposed", "implemented", "verified", "reviewed"] }
  },
  "$defs": { "nonEmptyStrings": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } },
  "allOf": [
    {
      "if": { "properties": { "actorRole": { "const": "frontier" } }, "required": ["actorRole"] },
      "then": { "properties": { "effectsPreset": { "const": "orchestration_local_write" } } }
    }
  ],
  "additionalProperties": true
}
