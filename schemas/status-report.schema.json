{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openaccp.dev/schemas/status-report.schema.json",
  "title": "OpenACCP Status Report",
  "type": "object",
  "required": ["schemaVersion", "artifactType", "responseId", "basisRefs", "currentState", "completedWork", "unverifiedClaims", "blockers", "nextActions", "authorityLimits"],
  "properties": {
    "schemaVersion": { "const": "openaccp-status-report.v1" },
    "artifactType": { "enum": ["status-report", "formal-report", "human-status"] },
    "responseId": { "type": "string", "minLength": 1 },
    "reportId": { "type": "string", "deprecated": true },
    "basisRefs": { "$ref": "#/$defs/nonEmptyStrings" },
    "currentState": { "type": "string", "minLength": 1 },
    "completedWork": { "type": "array", "items": { "type": "string" } },
    "unverifiedClaims": { "type": "array", "items": { "type": "string" } },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "nextActions": { "$ref": "#/$defs/nonEmptyStrings" },
    "authorityLimits": { "$ref": "#/$defs/nonEmptyStrings" }
  },
  "$defs": { "nonEmptyStrings": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } },
  "additionalProperties": true
}
